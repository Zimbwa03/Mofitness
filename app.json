{
  "expo": {
    "name": "Mofitness",
    "slug": "mofitness",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/33bf909d-ee98-419c-828b-a10df8ad3d9e"
    },
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "To analyse your exercise form in real time without recording video",
        "NSLocationWhenInUseUsageDescription": "To track your run route in real time",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "To continue tracking when you minimize the app",
        "NSLocationAlwaysUsageDescription": "To track your run in the background",
        "NSMotionUsageDescription": "To count your steps and strides"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0A",
        "foregroundImage": "./assets/app-icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "ACTIVITY_RECOGNITION",
        "FOREGROUND_SERVICE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "ACTIVITY_RECOGNITION",
        "FOREGROUND_SERVICE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.nerdx15.mofitness"
    },
    "web": {
      "favicon": "./assets/app-icon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Mofitness to analyse your exercise form in real time."
        }
      ],
      "expo-notifications",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-sharing",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "To track your run route in real time",
          "locationAlwaysAndWhenInUsePermission": "To continue tracking when you minimize the app",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "scheme": "mofitness",
    "extra": {
      "eas": {
        "projectId": "33bf909d-ee98-419c-828b-a10df8ad3d9e"
      }
    }
  }
}
